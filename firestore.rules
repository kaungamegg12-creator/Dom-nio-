rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: channels
    // Fields:
    //   - name: string (required, 1-50 chars)
    //   - createdAt: number (required)
    //
    // Collection: messages
    // Fields:
    //   - channelId: string (required)
    //   - author: string (required, 1-50 chars)
    //   - content: string (optional, 0-2000 chars)
    //   - imageUrl: string (optional, URL format)
    //   - imageLayout: string (optional, enum: normal, full, center)
    //   - color: string (optional, hex format)
    //   - authorColor: string (optional, hex format)
    //   - authorFont: string (optional)
    //   - authorBold: bool (optional)
    //   - authorItalic: bool (optional)
    //   - timestamp: number (required)
    //   - reactions: map (optional, emoji keys to list of userIds)
    //
    // Collection: settings
    // Fields:
    //   - name: string (required, 1-100 chars)
    //
    // Collection: userProfiles
    // Fields:
    //   - userId: string (required)
    //   - nameColor: string (optional)
    //   - fontFamily: string (optional)
    //   - isBold: bool (optional)
    //   - isItalic: bool (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      // O usuário solicitou a remoção da restrição por Gmail.
      // Para manter a segurança contra "hacks" (como flooding ou dados inválidos),
      // focamos na validação rigorosa dos dados abaixo.
      // Para segurança total de acesso, recomenda-se usar o Login do Google do Firebase.
      return true;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, min, max) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= min && 
             request.resource.data[field].size() <= max;
    }

    function isValidOptionalString(field, max) {
      return !(field in request.resource.data) || 
             (request.resource.data[field] == null) ||
             (request.resource.data[field] is string && request.resource.data[field].size() <= max);
    }

    function isValidUrl(field) {
      return !(field in request.resource.data) || 
             request.resource.data[field] == null || 
             (request.resource.data[field] is string && (request.resource.data[field].matches("^https://.*") || request.resource.data[field].matches("^http://.*")));
    }

    function isRecent(field) {
      return request.resource.data[field] is number && 
             request.resource.data[field] > (request.time.toMillis() - 3600000) && // within last hour
             request.resource.data[field] < (request.time.toMillis() + 3600000);   // within next hour (clock skew)
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /channels/{channelId} {
      allow read: if true;
      allow create: if isAdmin() && 
                      hasRequiredFields(['name', 'createdAt']) && 
                      isValidString('name', 1, 50) &&
                      isRecent('createdAt') &&
                      (!('color' in request.resource.data) || request.resource.data.color is string);
      allow update: if isAdmin() && 
                      isValidString('name', 1, 50) &&
                      (!('color' in request.resource.data) || request.resource.data.color is string);
      allow delete: if isAdmin();
    }
    
    match /messages/{messageId} {
      allow read: if true;
      // Anyone can create a message for now as the app uses custom auth, 
      // but we validate the data strictly.
      allow create: if hasRequiredFields(['channelId', 'author', 'timestamp']) &&
                      isValidString('author', 1, 50) &&
                      isValidOptionalString('content', 2000) &&
                      isValidUrl('imageUrl') &&
                      isRecent('timestamp') &&
                      (!('authorUID' in request.resource.data) || request.resource.data.authorUID is string) &&
                      (!('poll' in request.resource.data) || (
                        request.resource.data.poll is map &&
                        request.resource.data.poll.question is string &&
                        request.resource.data.poll.options is list &&
                        (!('expiresAt' in request.resource.data.poll) || request.resource.data.poll.expiresAt is number)
                      ));
      
      // Only admins can delete messages
      allow delete: if isAdmin();
      
      // Allow updates for reactions and polls
      allow update: if (request.resource.data.diff(resource.data).affectedKeys().hasAny(['reactions', 'poll'])) ||
                      (isAdmin());
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && 
                     isValidString('name', 1, 100);
    }
    
    match /userProfiles/{profileId} {
      allow read: if true;
      // In this app, admins manage profiles via the UI, 
      // but we should restrict it to admins or the owner if we had real auth.
      allow write: if isAdmin() || (isAuthenticated() && request.auth.uid == profileId);
    }

    match /presence/{userId} {
      allow read: if true;
      allow write: if true; // In a real app, we would check if request.auth.uid == userId
    }
    
    match /test/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
